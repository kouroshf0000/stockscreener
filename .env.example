ANTHROPIC_API_KEY=sk-ant-...
FRED_API_KEY=

DATABASE_URL=postgresql+asyncpg://alpha:alpha@localhost:5432/alpha
REDIS_URL=redis://localhost:6379/0

ENV=dev
LOG_LEVEL=INFO

CACHE_TTL_FUNDAMENTALS_S=86400
CACHE_TTL_QUOTES_S=900
CACHE_TTL_HAIKU_S=300

EQUITY_RISK_PREMIUM=0.055
UNIVERSE=SP500,NDX

# Model selection — default Haiku (~$0.024/ticker). Switch to Sonnet for premium
# narrative quality (~$0.067/ticker). Leave risk_model on Haiku — Sonnet adds nothing
# for structured JSON scoring.
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6
NARRATIVE_MODEL=claude-haiku-4-5-20251001
RISK_MODEL=claude-haiku-4-5-20251001

# Alpaca Markets — real-time quotes
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
